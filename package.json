{
  "name": "@neogroup/neorm",
  "version": "0.0.10",
  "description": "Database connector and ORM for javascript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "author": "Luis Manuel Amengual",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/luismanuelamengual/neogroup-neorm/issues"
  },
  "homepage": "https://github.com/luismanuelamengual/neogroup-neorm#readme",
  "keywords": [
    "database",
    "connector",
    "javascript",
    "typescript",
    "orm",
    "mysql",
    "postgres"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luismanuelamengual/neogroup-neorm.git"
  },
  "scripts": {
    "build": "jest --passWithNoTests && npm run clean && tsc",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "jest",
    "lint": "eslint src test --ext .ts,.js --fix",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^5.47.0",
    "@typescript-eslint/parser": "^5.47.0",
    "dotenv": "^16.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-absolute-imports-only": "^1.0.1",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "jest": "^29.7.0",
    "mysql2": "^3.0.0",
    "pg": "^8.7.1",
    "prettier": "^2.6.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
